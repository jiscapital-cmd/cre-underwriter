# Claude API key for document extraction (server-side only, never expose to client)
ANTHROPIC_API_KEY=

# Supabase project (Settings > API in your Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key used by API routes for writes — server-side only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# Shared password required to access the app (middleware.ts). Leave unset for
# local dev if you don't want the gate; set it before any public deployment.
APP_PASSWORD=
